# =============================================================================
# Crypto Trading Assistant — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Anthropic Claude API
# Required for: ai-service strategy generation and learning loop
# Get your key at: https://console.anthropic.com/
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here

# -----------------------------------------------------------------------------
# Binance Futures API
# Only required for private endpoints (e.g., placing orders — not used yet).
# Public WebSocket streams and REST kline endpoints work without keys.
# Get your keys at: https://www.binance.com/en/my/settings/api-management
# -----------------------------------------------------------------------------
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret

# -----------------------------------------------------------------------------
# PostgreSQL
# Defaults match the local-application-setup/docker-compose.yml values.
# Override when connecting to a remote database.
# -----------------------------------------------------------------------------
POSTGRES_URL=jdbc:postgresql://localhost:5432/trading
POSTGRES_HOST=localhost
POSTGRES_USER=trading
POSTGRES_PASSWORD=trading

# -----------------------------------------------------------------------------
# Kafka
# Defaults to the local Docker Compose Kafka instance.
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# -----------------------------------------------------------------------------
# Service URLs (used by services that call each other)
# These defaults work for local development with all services running.
# -----------------------------------------------------------------------------
TRADING_ENGINE_URL=http://localhost:8082
STRATEGY_SERVICE_URL=http://localhost:8083
AI_SERVICE_URL=http://localhost:8084
SIM_SERVICE_URL=http://localhost:8082

# -----------------------------------------------------------------------------
# Frontend
# The VITE_ prefix exposes variables to the Vite/React build.
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8080
