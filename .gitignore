# =============================================================================
# Crypto Trading Assistant — Root .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets and environment configuration — NEVER commit these
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.secret
secrets/

# -----------------------------------------------------------------------------
# Java / Maven build artifacts
# -----------------------------------------------------------------------------
**/target/
**/.mvn/wrapper/maven-wrapper.jar
**/mvnw.cmd
*.class
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Exclude the project's own .zip archive
trading-engine-copy.zip

# -----------------------------------------------------------------------------
# IDE and editor files
# -----------------------------------------------------------------------------
.idea/
*.iml
*.iws
*.ipr
.project
.classpath
.settings/
*.factorypath
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Node.js / Frontend
# -----------------------------------------------------------------------------
frontend/node_modules/
frontend/dist/
frontend/.cache/
frontend/.vite/
frontend/*.local

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
spring.log

# -----------------------------------------------------------------------------
# Docker volumes (if bind-mounted locally)
# -----------------------------------------------------------------------------
pgdata/

# -----------------------------------------------------------------------------
# OS generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
